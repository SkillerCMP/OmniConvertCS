/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MENU1 MENU 
BEGIN
    POPUP "File"
    BEGIN
        POPUP "Load"
        BEGIN
            MENUITEM "Text File...",                 ID_FILE_LOADTEXT
            MENUITEM "CodeBreaker CBC...",           ID_FILE_LOADCBC
            MENUITEM "AR MAX BIN...",                ID_FILE_LOADARMAXBIN
            MENUITEM "XP/GS P2M...",                 ID_FILE_LOADP2M
            MENUITEM "Swap Magic BIN...",            ID_FILE_LOADSMC
        END
        POPUP "Save As"
        BEGIN
            MENUITEM "Text / PNACH / MIPS...\tCtrl + S", ID_FILE_SAVEASTEXT
            MENUITEM "CodeBreaker CBC...",               ID_FILE_SAVEASCBC
            MENUITEM "AR MAX BIN...",                    ID_FILE_SAVEASARMAX
            MENUITEM "XP/GS P2M...",                     ID_FILE_SAVEASP2M
            MENUITEM "Swap Magic BIN...",                ID_FILE_SAVEASSMC
        END
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tESC",                  ID_FILE_EXIT
    END
    POPUP "Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM "&Delete \tDel",               ID_EDIT_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Select &All\tCtrl+A",         ID_EDIT_SELECTALL
        MENUITEM SEPARATOR
        MENUITEM "S&wap Input && Output	Ctrl+Shift+S", ID_EDIT_SWAP
        MENUITEM SEPARATOR
        MENUITEM "Clear Input",                 ID_EDIT_CLEAR_INPUT
        MENUITEM "Clear Output",                ID_EDIT_CLEAR_OUTPUT
    END
    POPUP "Input"
    BEGIN
        POPUP "Unencrypted"
        BEGIN
            MENUITEM "Standard",                    ID_INPUT_UNENC_COMMON
            MENUITEM "INLINE (from CRYPT_ headers)",  ID_INPUT_UNENC_INLINE
            MENUITEM "PS2 MIPS (R5900)",             ID_INPUT_UNENC_MIPS
            MENUITEM "Pnach (RAW)",                  ID_INPUT_UNENC_PNACH
            MENUITEM "Action Replay MAX",           ID_INPUT_UNENC_ARMAX
	    MENUITEM "Action Replay V1/V2",         ID_INPUT_UNENC_AR1_2
	    MENUITEM "CodeBreaker",                 ID_INPUT_UNENC_CB
	    MENUITEM "GameShark V1/V2",             ID_INPUT_UNENC_GS1_2
	    MENUITEM "Xploder/GameShark V3",        ID_INPUT_UNENC_XP
        END
        POPUP "Action Replay"
        BEGIN
            MENUITEM "Version 1",                   ID_INPUT_AR2_V1
            MENUITEM "Version 2",                   ID_INPUT_AR2_V2
            MENUITEM "MAX",                         ID_INPUT_ARMAX
        END
        POPUP "CodeBreaker"
        BEGIN
            MENUITEM "Version 1+ (All v7 Keys)",    ID_INPUT_CB
            MENUITEM "Version 7+ (Common Key)",     ID_INPUT_CB7_COMMON
        END
        POPUP "GameShark"
        BEGIN
            POPUP "Interact"
            BEGIN
                MENUITEM "Version 1",                   ID_INPUT_IA_V1
                MENUITEM "Version 2",                   ID_INPUT_IA_V2
            END
            POPUP "MadCatz"
            BEGIN
                MENUITEM "Version 3 - 4",               ID_INPUT_MC_V3
                MENUITEM "Version 5+",                  ID_INPUT_MC_V5
            END
        END
	POPUP "Swap Magic"
	BEGIN
	    MENUITEM "Coder Version 3.x",	    ID_INPUT_SMC
	END
        POPUP "Xploder"
        BEGIN
            MENUITEM "Version 1 - 3",               ID_INPUT_XP_V1
            MENUITEM "Version 4",                   ID_INPUT_XP_V4
	    MENUITEM "Version 5+",                  ID_INPUT_XP_V5
        END
    END
    POPUP "Output"
    BEGIN
        POPUP "Unencrypted"
        BEGIN
            MENUITEM "Standard",                    ID_OUTPUT_UNENC_COMMON
            MENUITEM "PS2 MIPS (R5900)",             ID_OUTPUT_UNENC_MIPS
            MENUITEM "Pnach (RAW)",                  ID_OUTPUT_UNENC_PNACH
            MENUITEM "Action Replay MAX",           ID_OUTPUT_UNENC_ARMAX
	    MENUITEM "Action Replay V1/V2",         ID_OUTPUT_UNENC_AR1_2
	    MENUITEM "CodeBreaker",                 ID_OUTPUT_UNENC_CB
	    MENUITEM "GameShark V1/V2",             ID_OUTPUT_UNENC_GS1_2
	    MENUITEM "Xploder/GameShark V3",        ID_OUTPUT_UNENC_XP
        END
        POPUP "Action Replay"
        BEGIN
            MENUITEM "Version 1",                   ID_OUTPUT_AR2_V1
            MENUITEM "Version 2",                   ID_OUTPUT_AR2_V2
            MENUITEM "MAX",                         ID_OUTPUT_ARMAX
        END
        POPUP "CodeBreaker"
        BEGIN
	    MENUITEM "Version 1+ (All v7 Keys)",    ID_OUTPUT_CB
            MENUITEM "Version 7+ (Common Key)",     ID_OUTPUT_CB7_COMMON
        END
        POPUP "GameShark"
        BEGIN
            POPUP "Interact"
            BEGIN
                MENUITEM "Version 1",                   ID_OUTPUT_IA_V1
                MENUITEM "Version 2",                   ID_OUTPUT_IA_V2
            END
            POPUP "MadCatz"
            BEGIN
                MENUITEM "Version 3 - 4",               ID_OUTPUT_MC_V3
                MENUITEM "Version 5+",                  ID_OUTPUT_MC_V5
            END
        END
	POPUP "Swap Magic"
	BEGIN
		MENUITEM "Coder Version 3.x",	    ID_OUTPUT_SMC
	END
        POPUP "Xploder"
        BEGIN
            MENUITEM "Version 1 - 3",               ID_OUTPUT_XP_V1
            MENUITEM "Version 4",                   ID_OUTPUT_XP_V4
	    MENUITEM "Version 5+",                  ID_OUTPUT_XP_V5
        END
    END
    POPUP "Options"
    BEGIN
        POPUP "Omni Options"
        BEGIN
            POPUP "Transpose Type"
            BEGIN
                MENUITEM "Strict",                  ID_TRANSPOSE_STRICT
                MENUITEM "Original",                ID_TRANSPOSE_ORIGINAL
            END
            MENUITEM "CMP Output Mode",             ID_OPTION_CMP_OUTPUT
            MENUITEM "MGS C-Type Pointer Mode",     ID_OPTION_MGS_CTYPE_POINTER
        END
        MENUITEM SEPARATOR
        MENUITEM "Make Organizers",                 ID_OPTION_MAKEFOLDERS
        MENUITEM SEPARATOR
        MENUITEM "AR MAX Options...\tCtrl+M",      ID_OPTIONS_ARMAX
        MENUITEM SEPARATOR
        MENUITEM "Set PNACH CRC...",                ID_OPTIONS_PNACH_CRC
        MENUITEM "Set AR2 Key Code...\tCtrl+K",   ID_AR2_KEY
        POPUP "GS3 Key"
        BEGIN
            MENUITEM "0",                           ID_GS3_KEY_0
            MENUITEM "1",                           ID_GS3_KEY_1
            MENUITEM "2",                           ID_GS3_KEY_2
            MENUITEM "3",                           ID_GS3_KEY_3
            MENUITEM "4",                           ID_GS3_KEY_4
        END
        POPUP "CBC Save Version"
        BEGIN
            MENUITEM "Version 7 (Day1)",             ID_OPTIONS_CBC_V7
            MENUITEM "Version 8 (CFU)",              ID_OPTIONS_CBC_V8
        END
    END
END

