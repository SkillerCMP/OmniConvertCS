IDD_DIALOG1 DIALOGEX 0, 0, 500, 340
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_THICKFRAME | WS_CLIPCHILDREN
CAPTION ""
MENU IDR_MENU1
FONT 9, "MS Shell Dlg 2", 400, 0, 0x0
BEGIN
    LTEXT           "Input: RAW / Standard",ID_STATIC_INPUT,7,7,100,10
    LTEXT           "In AR2 key:",ID_STATIC_AR2_CURRENT,110,7,42,10
    COMBOBOX        IDC_EDIT_AR2_CURRENT,153,5,50,70,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Clear",ID_BTN_CLEAR_IN,205,5,42,14
    LTEXT           "Output: RAW / Standard",ID_STATIC_OUTPUT,253,7,115,10
    LTEXT           "Out AR2:",ID_STATIC_AR2_OUTPUT_CURRENT,339,7,45,10
    COMBOBOX        IDC_AR2_OUTPUT_CURRENT,383,5,64,70,CBS_DROPDOWN | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Clear",ID_BTN_CLEAR_OUT,451,5,42,14
    LTEXT           "Game ID:",ID_STATIC_GAMEID_INPUT,150,7,38,10
    EDITTEXT        IDC_EDIT_GAMEID_INPUT,190,5,30,14,ES_UPPERCASE | ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Game ID:",ID_STATIC_GAMEID_OUTPUT,390,7,38,10
    EDITTEXT        IDC_EDIT_GAMEID_OUTPUT,430,5,30,14,ES_UPPERCASE | ES_AUTOHSCROLL | WS_TABSTOP
    EDITTEXT        IDC_EDIT_IN,7,22,240,270,ES_MULTILINE | ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_HSCROLL | WS_TABSTOP
    EDITTEXT        IDC_EDIT_OUT,253,22,240,270,ES_MULTILINE | ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_HSCROLL | WS_TABSTOP
    PUSHBUTTON      "Convert",ID_BTN_CONVERT,7,299,48,15
    PUSHBUTTON      "Swap",ID_BTN_SWAP,59,299,42,15
    LTEXT           "Game ID:",ID_STATIC_GAMEID,111,302,33,8
    EDITTEXT        IDC_EDIT_GAMEID,146,299,52,15,ES_AUTOHSCROLL | WS_TABSTOP
    LTEXT           "Game Name:",ID_STATIC_GAMENAME,208,302,43,8
    EDITTEXT        IDC_EDIT_GAMENAME,253,299,240,15,ES_AUTOHSCROLL | WS_TABSTOP
    CONTROL         "Add CRC",IDC_CHECK_PNACH_CRC,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,407,5,44,14
